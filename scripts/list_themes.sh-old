#!/bin/bash
# A simple script to list available syntax themes that can be configuring in `dan`.
# It builds and runs a small tool containing the `syntect-assets` used by the editor.

# Run from anywhere, it navigates to the project directory
PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." >/dev/null 2>&1 && pwd)"
cd "$PROJECT_DIR" || exit 1

echo "Building theme list tool..."
cargo run --release --bin list_themes --quiet
